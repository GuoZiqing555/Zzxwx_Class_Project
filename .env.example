# Copy this file to .env on the server; never commit or share the real key.
DEEPSEEK_API_KEY=replace_with_a_new_rotated_key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Hard global cap: counts every upstream request, including retry requests.
DAILY_API_CALL_LIMIT=50
QUOTA_TIMEZONE=Asia/Shanghai
QUOTA_DB_PATH=data/quota.sqlite3

# Used by docker-compose.yml and Caddy for HTTPS.
DOMAIN=demo.example.com
